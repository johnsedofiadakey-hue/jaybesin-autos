rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper: Is the user the authenticated admin?
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@jaybesin.com';
    }

    // Relaxed for rapid development & Quick-Access testing
    match /{allPaths=**} {
      allow read: if true;
      allow write: if true; 
    }
  }
}
