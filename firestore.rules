rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. PUBLIC READ: Allow everyone to read any collection
    match /{document=**} {
      allow read: if true;
    }

    // 2. ADMIN WRITE: Requires correct email
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@jaybesin.com';
    }

    match /inquiries/{docId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow write: if isAdmin();
    }
  }
}
