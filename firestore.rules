rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Is the user the authenticated admin?
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@jaybesin.com';
    }

    // Settings, Vehicles, Marketplace Cars, Charging, Parts
    // Publicly readable for browsing; only Admin can modify.
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /vehicles/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /cars/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /charging/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /parts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Inquiries: Anyone can SUBMIT (create); only Admin can read/manage.
    match /inquiries/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Orders: Publicly readable (for Tracking feature); only Admin can create/manage.
    match /orders/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny for everything else.
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
